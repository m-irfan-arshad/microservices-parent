
# POSTGRES Database configuration
POSTGRES_VERSION=18
DB_HOST=localhost
DB_HOST_PORT=5432
DB_CONTAINER_PORT=5433
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# PgAdmin configuration
PGADMIN_HOST_PORT=8080
PGADMIN_CONTAINER_PORT=80
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# Application configuration Common for all services


SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_LIQUIBASE_ENABLED=false
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Configuration for auth-service
APP_PORT=8082
APP_INTERNAL_PORT=8082
AUTH_SERVICE_NAME=auth-service
POSTGRES_DB_AUTH=auth_service_db

# Configuration for users-service
USERS_APP_PORT=8083
USERS_APP_INTERNAL_PORT=8083
SPRING_APPLICATION_NAME_USERS=users-service
POSTGRES_DB_USERS=users_service_db

SPRING_DOCKER_COMPOSE_ENABLED=true


